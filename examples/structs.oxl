struct MyStruct {
  foo: i32 = 0;
}

fn increment(self: MyStruct, by: mut i32) -> i32 {
  self.foo += by;

  return self.foo;
}

fn main() -> i32 {
  let a: MyStruct;      // immutable, MyStruct (default initialized)
  let b: mut MyStruct;  // mutable, MyStruct (default initialized)
  let c: i32 = 0;       // immutable, i32
  let d = mut 0;        // mutable, i32

  b.increment(23);
}
